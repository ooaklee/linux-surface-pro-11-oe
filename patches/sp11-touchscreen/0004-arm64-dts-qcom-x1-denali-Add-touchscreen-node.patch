From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: x1e-nixos <noreply@scug.io>
Date: Thu, 2 Jul 2026 00:00:00 +0000
Subject: [PATCH 4/4] arm64: dts: qcom: x1-denali: Add touchscreen node and pinctrl

Add the SPI10 QSPI controller, pinctrl configuration, and a
hid-over-spi touchscreen node. The touchscreen is the primary
input device on the Surface Pro 11.

SPI10 uses the qcom,geni-spi-qspi compatible for QSPI 1-4-4
mode. The touchscreen uses single-lane SPI for the HID-over-SPI
protocol (spi-rx-bus-width = spi-tx-bus-width = 1) but is
connected to a QSPI controller whose io mux and GENI protocol
require QSPI PCI driver setup.

Pinctrl reserves GPIO 44-47 for the SPI TPM and configures
SPI10 pins as function 1 (qup_se10_spi_cs/clk/miso/mosi).

Signed-off-by: x1e-nixos <noreply@scug.io>
---
 .../arm64/boot/dts/qcom/x1-microsoft-denali.dtsi  | 43 ++++++++++++++++++++++
 1 file changed, 43 insertions(+)

diff --git a/arch/arm64/boot/dts/qcom/x1-microsoft-denali.dtsi b/arch/arm64/boot/dts/qcom/x1-microsoft-denali.dtsi
index 950dc91..d91396c 100644
--- a/arch/arm64/boot/dts/qcom/x1-microsoft-denali.dtsi
+++ b/arch/arm64/boot/dts/qcom/x1-microsoft-denali.dtsi
@@ -270,6 +270,20 @@
 		regulator-boot-on;
 	};
 
+	vreg_ts_5p0: ts-5p0-regulator {
+		compatible = "regulator-fixed";
+		regulator-name = "vreg_ts_5p0";
+
+		regulator-min-microvolt = <5000000>;
+		regulator-max-microvolt = <5000000>;
+
+		gpio = <&tlmm 64 GPIO_ACTIVE_HIGH>;
+		enable-active-high;
+
+		pinctrl-names = "default";
+		pinctrl-0 = <&ts_5v_en_default_state>;
+	};
+
 	vreg_wcn_3p3: regulator-wcn-3p3 {
 		compatible = "regulator-fixed";
 
@@ -1208,8 +1222,72 @@
 		drive-strength = <2>;
 		bias-disable;
 	};
+
+	spi10_hid0_reset_deassert: spi10-hid1-reset-deassert {
+		pins = "gpio48";
+		function = "gpio";
+
+		drive-strength = <2>;
+		bias-disable;
+		output-high;
+	};
+
+	spi10_hid0_reset_assert: spi10-hid1-reset-assert {
+		pins = "gpio48";
+		function = "gpio";
+
+		drive-strength = <2>;
+		bias-disable;
+		output-low;
+	};
+
+	spi10_hid0_int_bias: spi10-hid1-int-bias {
+		pins = "gpio51";
+		function = "gpio";
+
+		input-enable;
+		bias-pull-up;
+	};
+
+	spi10_hid0_int_unbias: spi10-hid1-int-unbias {
+		pins = "gpio51";
+		function = "gpio";
+
+		input-enable;
+		bias-disable;
+	};
+
+	ts_5v_en_default_state: ts-5v-en-default-state {
+		pins = "gpio64";
+		function = "gpio";
+
+		drive-strength = <2>;
+		bias-disable;
+	};
 };
 
+
+&spi10 {
+	compatible = "qcom,geni-spi-qspi";
+	dmas = <&gpi_dma1 0 2 QCOM_GPI_QSPI>,
+	       <&gpi_dma1 1 2 QCOM_GPI_QSPI>;
+
+	status = "okay";
+
+	touchscreen@0 {
+		compatible = "hid-over-spi";
+		reg = <0>;
+		spi-max-frequency = <20000000>;
+
+		interrupts-extended = <&tlmm 51 IRQ_TYPE_EDGE_FALLING>;
+		reset-gpios = <&tlmm 48 GPIO_ACTIVE_HIGH>;
+
+		vdd-supply = <&vreg_ts_5p0>;
+		spi-tx-bus-width = <1>;
+		spi-rx-bus-width = <1>;
+		hid-descr-addr = <1>;
+	};
+};
 &uart2 {
 	status = "okay";
 
-- 
